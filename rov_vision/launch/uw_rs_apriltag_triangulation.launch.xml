<launch>
  <arg name="serial_no"         default=""/>
  <arg name="camera_name"       default="camera"/>
  <arg name="tag_family"        default="36h11"/>
  <arg name="tag_size"          default="0.1"/>
  <arg name="image_transport"   default="compressed"/>
  <arg name="left_input"        default="/camera/camera/infra1/image_rect_raw"/>
  <arg name="right_input"       default="/camera/camera/infra2/image_rect_raw"/>

  <include file="$(find-pkg-share realsense2_camera)/launch/rs_launch.py">
    <arg name="serial_no"                  value="$(var serial_no)"/>
    <arg name="camera_name"                value="$(var camera_name)"/>
    <arg name="enable_infra1"              value="true"/>
    <arg name="enable_infra2"              value="true"/>
    <arg name="enable_color"               value="false"/>
    <arg name="enable_depth"               value="false"/>
    <arg name="enable_sync"                value="true"/>
    <arg name="depth_module.infra_profile" value="848x480x30"/>
    <arg name="depth_module.emitter_enabled" value="0"/>
  </include>

  <include file="$(find-pkg-share jir_image_remapper)/launch/stereo_remapper.launch.py">
    <arg name="stereo"          value="true"/>
    <arg name="image_transport" value="$(var image_transport)"/>
    <arg name="left_input"      value="$(var left_input)"/>
    <arg name="right_input"     value="$(var right_input)"/>
  </include>

  <node pkg="rov_vision"
        exec="camera_info_publisher"
        name="left_camera_info_publisher"
        output="screen">
    <param name="camera_info_url"
           value="file://$(find-pkg-share rov_vision)/config/left_camera.yaml"/>
    <param name="camera_name"  value="left_camera"/>
    <param name="topic"        value="/rov/left/camera_info"/>
    <param name="frame_id"     value="left_camera_optical_frame"/>
    <param name="sync_topic"   value="/corrected/left/image_raw"/>
  </node>

  <node pkg="rov_vision"
        exec="camera_info_publisher"
        name="right_camera_info_publisher"
        output="screen">
    <param name="camera_info_url"
           value="file://$(find-pkg-share rov_vision)/config/right_camera.yaml"/>
    <param name="camera_name"      value="right_camera"/>
    <param name="topic"            value="/rov/right/camera_info"/>
    <param name="frame_id"         value="right_camera_optical_frame"/>
    <param name="parent_frame_id"  value="left_camera_optical_frame"/>
    <param name="sync_topic"       value="/corrected/right/image_raw"/>
    <param from="$(find-pkg-share rov_vision)/config/stereo_params.yaml"/>
  </node>

<node pkg="apriltag_ros" exec="apriltag_node" name="apriltag_node_left" output="screen">
    <param from="$(find-pkg-share rov_vision)/config/apriltag.yaml"/>
    <remap from="image_rect"                  to="/corrected/left/image_raw"/>
    <remap from="camera_info"                 to="/rov/left/camera_info"/>
    <remap from="detections"                  to="/detection1"/>
  </node>

  <node pkg="apriltag_ros" exec="apriltag_node" name="apriltag_node_right" output="screen">
    <param from="$(find-pkg-share rov_vision)/config/apriltag.yaml"/>
    <remap from="image_rect"                  to="/corrected/right/image_raw"/>
    <remap from="camera_info"                 to="/rov/right/camera_info"/>
    <remap from="detections"                  to="/detection2"/>
  </node>

  <node pkg="rov_vision"
        exec="stereo_triangulator"
        name="stereo_triangulate_node"
        output="screen">
    <param name="detection1_topic"        value="/detection1"/>
    <param name="detection2_topic"        value="/detection2"/>
    <param name="left_camera_info_topic"  value="/rov/left/camera_info"/>
    <param name="right_camera_info_topic" value="/rov/right/camera_info"/>
    <param name="corners_topic"           value="/apriltag/corners"/>
  </node>

</launch>
